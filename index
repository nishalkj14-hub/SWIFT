        </ScrollReveal>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-6">
          {newArrivals.map((product, i) => (
            <ScrollReveal key={product.id} animation="fade-up-stagger" delay={i * 80}>
              <ProductCard product={product} />
            </ScrollReveal>
          ))}
        </div>
      </section>

      <Footer />
    </div>
  );
};

export default Index;
