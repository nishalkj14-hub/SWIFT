const CountdownTimer = () => {
  const [time, setTime] = useState({ days: 0, hours: 0, mins: 0, secs: 0 });
  useEffect(() => {
    const end = new Date("2026-05-15T00:00:00").getTime();
    const tick = () => {
      const diff = Math.max(0, end - Date.now());
      setTime({
        days: Math.floor(diff / 86400000),
        hours: Math.floor((diff % 86400000) / 3600000),
        mins: Math.floor((diff % 3600000) / 60000),
        secs: Math.floor((diff % 60000) / 1000),
      });
    };
    tick();
    const id = setInterval(tick, 1000);
    return () => clearInterval(id);
  }, []);
  return (
    <div className="flex gap-3 justify-center">
      {Object.entries(time).map(([label, val]) => (
        <div key={label} className="text-center">
          <div className="w-16 h-16 rounded-xl bg-primary text-primary-foreground flex items-center justify-center font-display text-2xl font-bold shadow-lg">
            {String(val).padStart(2, "0")}
          </div>
          <p className="text-xs text-muted-foreground mt-1.5 capitalize font-medium">{label}</p>
        </div>
      ))}
    </div>
  );
};

